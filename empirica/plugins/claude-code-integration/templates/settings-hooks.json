{
  "_comment": "Add these hooks to ~/.claude/settings.json - replace PLUGIN_DIR with actual path",
  "_example_path": "~/.claude/plugins/local/empirica-integration",

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 PLUGIN_DIR/hooks/sentinel-gate.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 PLUGIN_DIR/hooks/sentinel-gate.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "python3 PLUGIN_DIR/hooks/pre-compact.py",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 PLUGIN_DIR/hooks/post-compact.py",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "python3 PLUGIN_DIR/hooks/ewm-protocol-loader.py",
            "timeout": 10,
            "allowFailure": true
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python3 PLUGIN_DIR/hooks/session-init.py",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "python3 PLUGIN_DIR/hooks/ewm-protocol-loader.py",
            "timeout": 10,
            "allowFailure": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 PLUGIN_DIR/hooks/tool-router.py",
            "timeout": 3,
            "allowFailure": true
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 PLUGIN_DIR/hooks/context-shift-tracker.py",
            "timeout": 5,
            "allowFailure": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 PLUGIN_DIR/hooks/session-end-postflight.py",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "python3 PLUGIN_DIR/hooks/curate-snapshots.py --output json",
            "timeout": 15,
            "allowFailure": true
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 PLUGIN_DIR/hooks/subagent-start.py",
            "timeout": 10,
            "allowFailure": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 PLUGIN_DIR/hooks/entity-extractor.py",
            "timeout": 5,
            "allowFailure": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 PLUGIN_DIR/hooks/subagent-stop.py",
            "timeout": 15,
            "allowFailure": true
          }
        ]
      }
    ]
  }
}
